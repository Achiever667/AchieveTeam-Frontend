{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "types": ["unplugin-vue-router/client"]
  },
  "include": [
    "env.d.ts", 
    "src/**/*.ts", 
    "src/**/*.tsx", 
    "src/**/*.vue", 
    "src/typed-router.d.ts"
  ]
}